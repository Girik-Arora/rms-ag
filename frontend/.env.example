# RMS·AG — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# STEP 1: Copy this file to .env.local (never commit .env.local to git!)
# STEP 2: Fill in your values from Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anonymous public key (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Spring Boot backend URL (local or deployed)
VITE_API_BASE_URL=http://localhost:8080
